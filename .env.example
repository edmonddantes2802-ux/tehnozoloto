# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Bitrix24
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/webhook-token/
BITRIX24_ASSIGNED_BY_ID=1

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_PHONE=79680952288

# YooKassa (получить после одобрения сайта в ЛК ЮKassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Admin panel (защита /admin)
# Без заданного ADMIN_PASSWORD вход в админку ЗАКРЫТ (никаких дефолтов).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Секрет для подписи сессии админки. Если пусто — деривируется от ADMIN_PASSWORD.
# Для прода задайте длинную случайную строку (например `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=

# AI-автозаполнение карточек товара (опционально).
# Кнопка «Распознать AI» в /admin/products/new работает если задан хотя бы один:
# 1) Anthropic Claude — приоритет, дешевле:
#    https://console.anthropic.com → API Keys → Create
ANTHROPIC_API_KEY=
# 2) OpenAI — fallback:
#    https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Telegram-уведомления о заказах.
# 1. Создайте бота через @BotFather → /newbot → токен ниже
# 2. С Telegram-аккаунта получателя (+79680952288) напишите боту /start
# 3. Откройте https://api.telegram.org/bot<TOKEN>/getUpdates, найдите "chat":{"id": <число>}
# 4. Если получателей несколько — TELEGRAM_CHAT_ID через запятую: "111,222"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
